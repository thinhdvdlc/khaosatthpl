# profiles/govdoc/profile.env — GovDoc AI (.NET 8 / Blazor Server, 1 app duy nhất).
# Sourced bởi bin/_common.sh. App nghe CẢ 2 port lane (api :800N + ui :300N) trong 1 process.

DB_URL_SCHEME="postgresql"                        # chỉ để dựng DATABASE_URL; hook .NET build conn-string riêng
API_PATH="/api"                                    # API mount; health vẫn ở /health (root)
UPLOAD_SUBDIR="src/GovDoc.Web/App_Data/uploads"    # per-lane upload dir (chính dùng MinIO/S3)
BACKEND_DIR="."                                     # .sln ở gốc repo (app .NET duy nhất)
FRONTEND_DIR=""                                     # Blazor Server: không có FE tách rời
DB_SERVICE="postgres"                              # tên service DB trong docker-compose
COMPOSE_SERVICES="postgres redis minio adminer"    # services db-shared-up.sh dựng (thêm minio cho S3)
BASE_BRANCH="main"                                 # nhánh base của MR
INTEGRATION_BRANCH="development"                   # nhánh integration / auto-deploy
BRANCH_PREFIX="feat/"                              # tiền tố nhánh feature
TEST_PATHS="tests/ *Tests.cs *.Tests/"             # test-only fast-path cho ship-feature
