# profiles/govdoc/integrations.env — bật/tắt tích hợp tổ chức (sourced bởi _common.sh).
# Mỗi tích hợp OFF mặc định; tắt => stage tương ứng bị bỏ qua.

# --- Tracker (Jira nội bộ) — bật khi muốn tự tạo ticket sau push ---
TRACKER_ENABLED=0
TRACKER_PROVIDER="jira"           # dùng MCP VNPT-Review-Bot (jira_*) thay cho agent Playwright
TRACKER_URL=""                    # URL Jira project/board
TRACKER_PROJECT=""                # mã project
TRACKER_STATUS="In Progress"
TRACKER_ASSIGNEE=""
TRACKER_MCP="VNPT-Review-Bot"     # các tool jira_* nằm trong MCP này

# --- Dev-site QC — browser-QC site dev sau push (cần SPA + tài khoản dev) ---
DEV_QC_ENABLED=0
DEV_SITE_URL=""
DEV_QC_MCP=""

# --- Chờ CI deploy trước dev-QC — dùng pipeline status của GitLab ---
CI_WAIT_ENABLED=0
CI_PROVIDER="gitlab-pipeline"     # KHÔNG phải github-status; watch qua GitLab-MCP (list_merge_request_pipelines)
CI_REPO=""                        # group/project trên GitLab
CI_DEPLOY_CONTEXT="deploy-dev"    # tên job deploy trong .gitlab-ci.yml
