# profiles/<your-project>/profile.env — your stack shape (sourced by bin/_common.sh).
# Fill these for your app; each overrides the harness default shown in [brackets].
# The /harness-adapt skill can infer most of these from your repo.

DB_URL_SCHEME="postgresql+asyncpg"          # driver scheme in DATABASE_URL          [postgresql+asyncpg]
API_PATH="/api/v1"                          # API mount path; health hits <API_PATH>/... [/api/v1]
UPLOAD_SUBDIR="backend/data/uploads"        # per-lane upload dir, relative to the clone [backend/data/uploads]
BACKEND_DIR="backend"                       # backend subdir in your repo               [backend]
FRONTEND_DIR="frontend"                     # frontend subdir in your repo              [frontend]
DB_SERVICE="postgres"                       # docker-compose service name for your DB   [postgres]
COMPOSE_SERVICES="postgres redis adminer"   # services db-shared-up.sh brings up        [postgres redis adminer]
BASE_BRANCH="main"                          # PR base branch                            [main]
INTEGRATION_BRANCH="development"            # integration / auto-deploy branch          [development]
BRANCH_PREFIX="feat/"                       # feature-branch prefix                     [feat/]
TEST_PATHS=""                               # space-separated path globs that count as test files (e.g. "tests/ *.test.* e2e/");
                                            #   ship-feature's test-only fast-path skips browser QC when a re-entry touches only these
