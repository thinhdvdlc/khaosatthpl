# profiles/<your-project>/integrations.env — optional org integrations (sourced by _common.sh).
# Each integration is OFF by default; a disabled integration's pipeline stage is skipped
# entirely, so a GitHub-only project runs implement -> ci-gate -> PR -> integrate ->
# local-QC -> senior-gate -> push without any of them. Turn one on by setting *_ENABLED=1
# and filling its fields (the /harness-adapt skill can do this for you).

TRACKER_ENABLED=0          # 1 = file a tracker ticket after a dev push
TRACKER_PROVIDER=""        # eastagile | jira | linear | github-issues  (generate the provider agent via /harness-adapt)
TRACKER_URL=""             # tracker project/issues URL
TRACKER_PROJECT=""         # project/board name
TRACKER_STATUS=""          # column/status to file under (e.g. Started / In Progress)
TRACKER_ASSIGNEE=""        # default assignee
TRACKER_MCP=""             # name of the Playwright MCP server scoped to the tracker

DEV_QC_ENABLED=0           # 1 = browser-QC a deployed dev site after push
DEV_SITE_URL=""            # e.g. https://dev.example.com
DEV_QC_MCP=""              # name of the Playwright MCP server scoped to the dev site

CI_WAIT_ENABLED=0          # 1 = wait for a deploy status before dev-QC
CI_PROVIDER="github-status"
CI_REPO=""                 # owner/repo whose commit status reports the deploy
CI_DEPLOY_CONTEXT=""       # the status context name to wait for (e.g. "ci/circleci: deploy-dev")
