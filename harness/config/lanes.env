# Harness configuration (non-secret). Sourced bởi bin/_common.sh.
# LƯU Ý: tools/new-project.sh sẽ GHI ĐÈ file này theo dự án của bạn — đây chỉ là mặc định generic.

HARNESS_ROOT="${HARNESS_ROOT:-$HOME/work/harness}"
LANES_ROOT="${LANES_ROOT:-$HOME/work}"                 # lane clones: $LANES_ROOT/laneN
SOURCE_REPO="${SOURCE_REPO:-$HOME/work/myapp}"         # repo app để lane clone từ đó (+ compose file)
ORIGIN_URL="${ORIGIN_URL:-}"                            # remote GitLab cho lane clones (git@gitlab...:team/app.git)
PROFILE="${PROFILE:-_template}"                         # profile: profiles/<PROFILE>/ (đổi = slug dự án)

# Shared services (một bộ cho mọi lane)
PG_HOST="${PG_HOST:-127.0.0.1}"
PG_PORT="${PG_PORT:-5433}"
PG_USER="${PG_USER:-postgres}"
PG_PASS="${PG_PASS:-postgres}"
REDIS_HOST="${REDIS_HOST:-127.0.0.1}"
REDIS_PORT="${REDIS_PORT:-6379}"

# Per-lane derivations
DB_PREFIX="${DB_PREFIX:-app_l}"                        # lane N -> app_l<N>
API_BASE_PORT="${API_BASE_PORT:-8000}"                 # lane N -> 8000+N
FE_BASE_PORT="${FE_BASE_PORT:-3000}"                   # lane N -> 3000+N
WORKER_QUEUES="${WORKER_QUEUES:-default}"

COMPOSE_FILE="${COMPOSE_FILE:-$SOURCE_REPO/docker-compose.yml}"

# Secrets (giá trị thật ở config/secrets.env — gitignored; copy từ secrets.env.example)
if [ -f "$HARNESS_ROOT/config/secrets.env" ]; then
  # shellcheck disable=SC1091
  source "$HARNESS_ROOT/config/secrets.env"
fi
SEED_USER_PASSWORD="${SEED_USER_PASSWORD:-changeme}"
SEED_USER_EMAIL="${SEED_USER_EMAIL:-admin@app.local}"
