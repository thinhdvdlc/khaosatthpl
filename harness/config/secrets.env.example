# Copy to config/secrets.env (gitignored) and fill in.
# Seed account used by lane-bootstrap. See your local_account memory.
export SEED_USER_PASSWORD='QaLocal2026!'
export SEED_USER_EMAIL='acme_admin@localadmin.com'

# Dev-site QA password (dev.stackclinical.com), shared by the per-lane QA
# accounts qa-lane<N>@eastagile.com. lane-bootstrap writes each lane's
# <lane>/.harness-qa.env (git-excluded) with DEV_QC_EMAIL=qa-lane<N>@... +
# this password; the dev-qc agent reads that file to (re-)login when the
# qa-dev Chromium profile session expires (~7 days).
export DEV_QC_PASSWORD='change-me'

# East Agile tracker login — used by the harness ticketer agent (tracker.eastagile.com).
export TRACKER_EMAIL='you@example.com'
export TRACKER_PASSWORD='change-me'

# Optional: absolute path to the dataset dir the browser-QC agents (qc-local /
# dev-qc) use for any file-upload scenario. Injected into those agents the same
# way credentials are. Leave empty to skip upload scenarios. Quote if it has
# spaces. (clinical example: 'Stack SDTM for East Agile')
export QC_UPLOAD_FIXTURES_DIR=''
