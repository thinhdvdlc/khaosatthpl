# profile.env — stack .NET (ASP.NET Core + EF Core). Sửa phần "App-specific" cho dự án của bạn.
DB_URL_SCHEME="postgresql"
API_PATH="/api"
UPLOAD_SUBDIR="src/App.Web/App_Data/uploads"
BACKEND_DIR="."
FRONTEND_DIR=""
DB_SERVICE="postgres"
COMPOSE_SERVICES="postgres redis minio adminer"
BASE_BRANCH="main"
INTEGRATION_BRANCH="development"
BRANCH_PREFIX="feat/"
TEST_PATHS="tests/ *Tests.cs *.Tests/"

# --- App-specific (SỬA cho dự án của bạn) ---
SLN="App.sln"                       # tên solution
WEB_PROJECT="src/App.Web"           # project khởi động (chứa Program.cs, /health, --seed)
INFRA_PROJECT="src/App.Infrastructure"  # project chứa DbContext/migrations
APP_DLL="App.Web.dll"               # tên dll sau publish
DUAL_PORT="1"                       # 1 = nghe cả API_PORT + FE_PORT (Blazor/MVC); 0 = chỉ API_PORT (API-only)
