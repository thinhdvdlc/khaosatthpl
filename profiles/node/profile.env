# profile.env — stack Node (NestJS/Express + Prisma). Driver nhận URL → dùng thẳng DATABASE_URL/REDIS_URL.
DB_URL_SCHEME="postgresql"
API_PATH="/api"
UPLOAD_SUBDIR="uploads"
BACKEND_DIR="."
FRONTEND_DIR=""
DB_SERVICE="postgres"
COMPOSE_SERVICES="postgres redis adminer"
BASE_BRANCH="main"
INTEGRATION_BRANCH="development"
BRANCH_PREFIX="feat/"
TEST_PATHS="test/ *.spec.ts *.e2e-spec.ts"

# --- App-specific (SỬA cho dự án của bạn) ---
PKG_MGR="npm"                     # npm | pnpm | yarn
BUILD_SCRIPT="build"              # $PKG_MGR run <...>
START_CMD="node dist/main.js"     # lệnh prod; đọc PORT / DATABASE_URL / REDIS_URL từ env
SEED_SCRIPT="seed"
LINT_SCRIPT="lint"
TEST_SCRIPT="test"
E2E_SCRIPT="test:e2e"
MIGRATE_CMD="npx prisma migrate deploy"
HEALTH_PATH="/health"
