# profile.env — stack Python (FastAPI + Alembic + SQLAlchemy). Driver nhận URL → dùng thẳng DATABASE_URL.
DB_URL_SCHEME="postgresql+asyncpg"
API_PATH="/api"
UPLOAD_SUBDIR="uploads"
BACKEND_DIR="."
FRONTEND_DIR=""
DB_SERVICE="postgres"
COMPOSE_SERVICES="postgres redis adminer"
BASE_BRANCH="main"
INTEGRATION_BRANCH="development"
BRANCH_PREFIX="feat/"
TEST_PATHS="tests/ test_*.py"

# --- App-specific (SỬA cho dự án của bạn) ---
PY="uv run"                          # uv run | poetry run | python  (runner)
INSTALL_CMD="uv sync"
MIGRATE_CMD="uv run alembic upgrade head"
LINT_CMD="uv run ruff check ."
APP_MODULE="app.main:app"            # cho uvicorn
SEED_MODULE="app.seed"              # python -m <SEED_MODULE>
HEALTH_PATH="/health"
