# CSDL PostgreSQL (Prisma Postgres / Neon / Vercel Postgres). KHÔNG commit .env thật.
# Lấy chuỗi kết nối từ nhà cung cấp DB, dán vào biến môi trường (local: .env, prod: Vercel env).
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"
# Cổng HTTP của server (chỉ dùng khi chạy Express thường; trên Vercel là serverless)
PORT=3000
# Khóa quản trị — ĐỔI trước khi triển khai thật
ADMIN_KEY=khaosat-admin
